# ── Sponsor stack keys ───────────────────────────────────────────────
# Nebius (Token Factory) — inference. https://tokenfactory.nebius.com
NEBIUS_API_KEY=
# Optional overrides:
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Tavily — web search. https://app.tavily.com  (key starts with tvly-)
TAVILY_API_KEY=

# Composio — actions (Gmail/Slack/Notion). https://app.composio.dev
COMPOSIO_API_KEY=
# The Composio "user id" your connected accounts belong to (any string you pick):
COMPOSIO_USER_ID=default

# ── Delivery targets (where Scout sends things) ──────────────────────
# Leave blank to keep that action in dry-run/echo mode.
SCOUT_TO_EMAIL=
SCOUT_SLACK_CHANNEL=
SCOUT_NOTION_PARENT_ID=

# Set to 1 to draft everything but never fire real actions (safe for demos).
SCOUT_DRY_RUN=1
